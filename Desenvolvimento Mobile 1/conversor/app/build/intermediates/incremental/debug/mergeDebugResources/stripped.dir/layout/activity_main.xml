<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0D0D1A"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"
        android:paddingTop="48dp"
        android:paddingBottom="32dp">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="32dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Conversor"
                android:textColor="#FFFFFF"
                android:textSize="30sp"
                android:textStyle="bold"/>

            <TextView
                android:id="@+id/tvUltimaAtualizacao"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=""
                android:textColor="#555577"
                android:textSize="11sp"/>
        </LinearLayout>

        <!-- Card Moeda de Origem -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_card_dark"
            android:padding="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="DE"
                android:textColor="#FF6B35"
                android:textSize="11sp"
                android:textStyle="bold"
                android:letterSpacing="0.15"
                android:layout_marginBottom="12dp"/>

            <Spinner
                android:id="@+id/spinnerOrigem"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:background="@drawable/bg_spinner"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:layout_marginBottom="16dp"/>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#252540"
                android:layout_marginBottom="16dp"/>

            <EditText
                android:id="@+id/etValor"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="0,00"
                android:textColor="#FFFFFF"
                android:textSize="40sp"
                android:textStyle="bold"
                android:background="@null"
                android:inputType="numberDecimal"
                android:gravity="end"
                android:singleLine="true"/>

            <TextView
                android:id="@+id/tvSiglaMoedaOrigem"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="BRL"
                android:textColor="#555577"
                android:textSize="13sp"
                android:gravity="end"
                android:layout_marginTop="4dp"/>
        </LinearLayout>

        <!-- Botão Swap centralizado -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="56dp">

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_gravity="center_vertical"
                android:background="#1A1A2E"/>

            <ImageButton
                android:id="@+id/btnTrocar"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_swap"
                android:background="@drawable/bg_button_swap"
                android:contentDescription="Trocar moedas"
                android:padding="12dp"/>
        </FrameLayout>

        <!-- Card Moeda de Destino -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_card_dark"
            android:padding="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="PARA"
                android:textColor="#FF6B35"
                android:textSize="11sp"
                android:textStyle="bold"
                android:letterSpacing="0.15"
                android:layout_marginBottom="12dp"/>

            <Spinner
                android:id="@+id/spinnerDestino"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:background="@drawable/bg_spinner"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:layout_marginBottom="16dp"/>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#252540"
                android:layout_marginBottom="16dp"/>

            <TextView
                android:id="@+id/tvResultado"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="0,00"
                android:textColor="#FF6B35"
                android:textSize="40sp"
                android:textStyle="bold"
                android:gravity="end"/>

            <TextView
                android:id="@+id/tvSiglaMoedaDestino"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="USD"
                android:textColor="#555577"
                android:textSize="13sp"
                android:gravity="end"
                android:layout_marginTop="4dp"/>
        </LinearLayout>

        <!-- Taxa de câmbio -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="8dp">

            <TextView
                android:id="@+id/tvTaxa"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Selecione as moedas e pressione Converter"
                android:textColor="#555577"
                android:textSize="13sp"/>
        </LinearLayout>

        <!-- Botão Converter -->
        <Button
            android:id="@+id/btnConverter"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="CONVERTER"
            android:textColor="#FFFFFF"
            android:textSize="15sp"
            android:textStyle="bold"
            android:letterSpacing="0.1"
            android:background="@drawable/bg_button_orange"
            android:layout_marginTop="16dp"/>

        <!-- Loading -->
        <ProgressBar
            android:id="@+id/progressBar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="16dp"
            android:visibility="gone"
            android:indeterminateTint="#FF6B35"/>

        <!-- Erro -->
        <TextView
            android:id="@+id/tvErro"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text=""
            android:textColor="#FF4444"
            android:textSize="13sp"
            android:gravity="center"
            android:layout_marginTop="8dp"
            android:visibility="gone"/>

        <!-- Rodapé informativo -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Taxas atualizadas diariamente • open.er-api.com"
            android:textColor="#333355"
            android:textSize="11sp"
            android:gravity="center"
            android:layout_marginTop="32dp"/>

    </LinearLayout>
</ScrollView>

<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="24dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Calculadora de juros"
            android:textSize="22sp"
            android:textStyle="bold"
            android:layout_marginBottom="24dp"/>

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etAmount"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/amount_hint"
                android:inputType="numberDecimal" />
        </com.google.android.material.textfield.TextInputLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/question_friendship"
            android:textColor="#E64A19"
            android:layout_marginBottom="8dp"/>

        <RadioGroup
            android:id="@+id/rgFriendship"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp">

            <RadioButton
                android:id="@+id/rbBestFriend"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/best_friend"
                android:checked="true"/>

            <RadioButton
                android:id="@+id/rbFriend"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/friend" />

            <RadioButton
                android:id="@+id/rbColleague"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/colleague" />

            <RadioButton
                android:id="@+id/rbStranger"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/stranger" />
        </RadioGroup>

        <com.google.android.material.switchmaterial.SwitchMaterial
            android:id="@+id/switchRound"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/round_switch"
            android:layout_marginBottom="32dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/result_label"
            android:layout_marginBottom="16dp"/>

        <TextView
            android:id="@+id/tvResult"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/default_result"
            android:textColor="#4CAF50"
            android:textSize="36sp"
            android:textAlignment="center"
            android:layout_marginBottom="48dp"/>

        <Button
            android:id="@+id/btnCalculate"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:text="@string/calculate_button"
            android:backgroundTint="#673AB7"
            android:textAllCaps="false"
            android:textSize="16sp"
            app:cornerRadius="16dp"/>

    </LinearLayout>
</ScrollView>